# --- Application ---
APP_NAME="Knowledge Sphere"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=ks-very-secure-secret-key-32-chars-length-minimum-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database (PostgreSQL) ---
POSTGRES_USER=knowledge_user
POSTGRES_PASSWORD=knowledge_pass
POSTGRES_DB=knowledge_sphere
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://knowledge_user:knowledge_pass@postgres:5432/knowledge_sphere

# --- Redis & Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=knowledge_neo4j_pass
NEO4J_DATABASE=neo4j

# --- ChromaDB ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_DOCUMENTS=documents_v2
CHROMA_COLLECTION_ENTITIES=entities_v2

# --- AI Providers (openai | gemini | ollama) ---
DEFAULT_LLM_PROVIDER=openai
DEFAULT_EMBEDDING_PROVIDER=openai

# Provide the API key for your chosen provider
OPENAI_API_KEY="sk-..."
GOOGLE_API_KEY="AIzaSy..."

# --- File Storage ---
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt,csv,html,htm

# --- CORS & Networking ---
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:80"]

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
